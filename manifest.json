{
  "manifest_version": 3,
  "name": "YouTube Focus Timer",
  "version": "1.1.0",
  "description": "Automatically hides YouTube home feed and Shorts after a configurable time limit to help you stay focused. Includes Focus Mode to block distracting sites.",
  "permissions": ["storage", "activeTab", "alarms"],
  "host_permissions": [
    "*://*.youtube.com/*",
    "*://*.x.com/*",
    "*://x.com/*",
    "*://*.twitter.com/*",
    "*://twitter.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://*.x.com/*",
        "*://x.com/*",
        "*://*.twitter.com/*",
        "*://twitter.com/*"
      ],
      "js": ["focus_block.js"],
      "css": ["focus_block.css"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
